{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc-project.github.io/json-schema/oxlint.json",
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "error"
  },
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": ["dist", "node_modules", "*.config.*"]
}
